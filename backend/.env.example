# Node Environment
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/polyibadan

# Server Port
PORT=3003

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# WhatsApp Configuration
WHATSAPP_ENABLED=false

# ==========================================
# BREVO (Sendinblue) EMAIL CONFIGURATION
# ==========================================
# Get your Brevo SMTP credentials from:
# https://app.brevo.com/settings/keys/smtp

# SMTP Username (your Brevo account email)
BREVO_SMTP_USER=your-brevo-smtp-user

# SMTP Password (API key or SMTP password from Brevo)
BREVO_SMTP_PASSWORD=your-brevo-smtp-password

# Sender email address (must be verified in Brevo)
BREVO_FROM_EMAIL=noreply@polyibadan.com

# Sender name
BREVO_FROM_NAME=Polyibadan Cooperative
